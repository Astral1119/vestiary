#!/bin/sh
set -eu

REPO_ROOT=$(cd "$(dirname "$0")" && pwd)

required_missing=0

report_dependency() {
  dependency=$1
  kind=$2
  consequence=$3

  # ghostty ships its CLI inside the app bundle, usually off PATH
  if [ "$dependency" = ghostty ] && [ -x "${LIVERY_GHOSTTY_BIN:-/Applications/Ghostty.app/Contents/MacOS/ghostty}" ]; then
    status=found
    consequence=''
    printf '  %-14s %-10s %-8s %s\n' "$dependency" "$kind" "$status" "$consequence"
    return
  fi
  if command -v "$dependency" >/dev/null 2>&1; then
    status=found
    consequence=''
  else
    status=missing
    if [ "$kind" = required ]; then
      required_missing=1
    fi
  fi

  printf '  %-14s %-10s %-8s %s\n' "$dependency" "$kind" "$status" "$consequence"
}

echo "dependencies"
printf '  %-14s %-10s %-8s %s\n' "command" "need" "status" "when missing"
report_dependency jq required "required for bootstrap"
report_dependency swiftc required "livery, lvry, and fresco compile Swift helpers"
report_dependency cargo optional "matugen fallback build (arm64 macs download a prebuilt)"
report_dependency ffmpeg optional "scene lock images + video frame extraction"
report_dependency tmux optional "the tmux surface won't be themed"
report_dependency nvim optional "the nvim surface won't be themed"
report_dependency ghostty optional "the ghostty surface won't be themed"
report_dependency sketchybar optional "the sketchybar surface won't be themed"
report_dependency borders optional "the borders surface won't be themed"
report_dependency yabai optional "borders loader rides yabairc"
report_dependency cava optional "fresco audio/now-playing"
report_dependency media-control optional "fresco audio/now-playing"
report_dependency steamcmd optional "workshop downloads (also needs Wallpaper Engine on Steam)"

if [ "$required_missing" -ne 0 ]; then
  echo "install: required dependencies are missing" >&2
  exit 1
fi

# fonts (contract §2.4.3): the map names every family the shipped surfaces
# need. Font casks install per-user, so this check is per-account. Missing
# fonts never fail the install — surfaces fall back per §2.4.1.
FONTS_MAP="$REPO_ROOT/contract/fonts-map.json"
echo ""
echo "fonts"
if ! command -v osascript >/dev/null 2>&1; then
  echo "  osascript unavailable — skipping the font check"
else
  installed_families=$(osascript -l JavaScript -e \
    'ObjC.import("AppKit"); $.NSFontManager.sharedFontManager.availableFontFamilies.js.map(function(f){return f.js}).join("\n")' \
    2>/dev/null || true)
  missing_casks=''

  family_installed() {
    printf '%s\n' "$installed_families" | grep -Fxq "$1"
  }

  while IFS="$(printf '\t')" read -r family cask why; do
    [ -n "$family" ] || continue
    if family_installed "$family"; then
      printf '  %-30s %-8s\n' "$family" found
    else
      printf '  %-30s %-8s %s (cask: %s)\n' "$family" missing "$why" "$cask"
      missing_casks="$missing_casks $cask"
    fi
  done <<FONTS
$(jq -r '.fonts[] | [.family, .cask, .why] | @tsv' "$FONTS_MAP")
FONTS

  while IFS="$(printf '\t')" read -r name path cask why; do
    [ -n "$name" ] || continue
    if [ -d "$path" ]; then
      printf '  %-30s %-8s\n' "$name" found
    else
      printf '  %-30s %-8s %s (cask: %s)\n' "$name" missing "$why" "$cask"
      missing_casks="$missing_casks $cask"
    fi
  done <<FONTS
$(jq -r '.apps[] | [.name, .path, .cask, .why] | @tsv' "$FONTS_MAP")
FONTS

  # families the user chose in ~/.config/livery/fonts.json that the map
  # doesn't know: report-only, no cask to offer.
  user_fonts="$HOME/.config/livery/fonts.json"
  if [ -r "$user_fonts" ]; then
    while IFS= read -r family; do
      [ -n "$family" ] || continue
      if ! family_installed "$family" \
        && ! jq -e --arg f "$family" '[.fonts[].family] | index($f)' "$FONTS_MAP" >/dev/null; then
        printf '  %-30s %-8s %s\n' "$family" missing \
          "chosen in fonts.json — no known cask, install by hand"
      fi
    done <<FONTS
$(jq -r '[.[]?.family // empty] | unique | .[]' "$user_fonts" 2>/dev/null || true)
FONTS
  fi

  if [ -n "$missing_casks" ]; then
    if command -v brew >/dev/null 2>&1; then
      want=n
      if [ -t 0 ]; then
        printf '  install the missing casks via brew?%s [y/N] ' "$missing_casks"
        read -r want || want=n
      fi
      case $want in
        y|Y)
          # shellcheck disable=SC2086 — cask names are unquoted by design
          brew install --cask $missing_casks || echo "  brew install had errors; fonts above stay missing"
          ;;
      esac
    else
      echo "  brew unavailable — install the casks above by hand"
    fi
  fi
fi

MATUGEN="$REPO_ROOT/livery/tools/bin/matugen"
if [ -x "$MATUGEN" ]; then
  printf '\nmatugen: '
  "$MATUGEN" --version
else
  echo ""
  echo "matugen: fetching pinned release"
  # arm64 downloads a prebuilt asset; other platforms build via cargo.
  "$REPO_ROOT/livery/tools/fetch-matugen" || true
fi

for shim in \
  "livery:livery/liveryctl" \
  "lvry:livery/lvry" \
  "fresco:fresco/fresco"; do
  target=${shim#*:}
  if [ ! -x "$REPO_ROOT/$target" ]; then
    echo "install: corrupt clone: missing executable $REPO_ROOT/$target" >&2
    exit 1
  fi
done

SHIM_DIR="$HOME/.local/bin"
mkdir -p "$SHIM_DIR"
expected_shim=$(mktemp "${TMPDIR:-/tmp}/vestiary-install.XXXXXX")
trap 'rm -f "$expected_shim"' 0
trap 'exit 1' HUP INT TERM

echo ""
echo "command shims"
for shim in \
  "livery:livery/liveryctl" \
  "lvry:livery/lvry" \
  "fresco:fresco/fresco"; do
  name=${shim%%:*}
  target=${shim#*:}
  shim_path="$SHIM_DIR/$name"
  printf '#!/bin/sh\nexec "%s/%s" "$@"\n' "$REPO_ROOT" "$target" > "$expected_shim"

  if [ -e "$shim_path" ] || [ -L "$shim_path" ]; then
    if cmp -s "$expected_shim" "$shim_path"; then
      chmod +x "$shim_path"
      echo "  $name: ok"
      continue
    fi

    existing_target=$(sed -n 's/^exec "\([^"]*\)" "\$@"$/\1/p' "$shim_path" 2>/dev/null || true)
    if [ -z "$existing_target" ]; then
      existing_target="unrecognized content at $shim_path"
    fi
    echo "  $name: kept existing target: $existing_target"
    echo "    remove $shim_path if you want it regenerated"
    continue
  fi

  cp "$expected_shim" "$shim_path"
  chmod +x "$shim_path"
  echo "  $name: installed -> $REPO_ROOT/$target"
done

case ":${PATH:-}:" in
  *":$SHIM_DIR:"*) ;;
  *) echo "warning: $SHIM_DIR is not in PATH" >&2 ;;
esac

# Loader wiring lives here rather than behind a new adapter verb: the
# contract's verb set is frozen, and editing user configs is installer
# policy, not adapter mechanism. Wiring only runs when asked (a TTY yes,
# or --wire); the report alone stays the non-interactive behavior.
backup_once() {
  [ -f "$1" ] && [ ! -e "$1.pre-livery" ] && cp "$1" "$1.pre-livery" || true
}

append_line() {
  target=$1
  line=$2
  mkdir -p "$(dirname "$target")"
  backup_once "$target"
  [ -f "$target" ] && [ -n "$(tail -c 1 "$target" 2>/dev/null)" ] && printf '\n' >> "$target"
  printf '%s\n' "$line" >> "$target"
}

wire_loader() {
  case $1 in
    tmux)
      append_line "$HOME/.config/tmux/tmux.conf" \
        'source-file -q ~/.config/livery/current/tmux/livery.conf' ;;
    ghostty)
      append_line "$HOME/.config/ghostty/config" \
        'config-file = ?../livery/current/ghostty/livery.conf' ;;
    borders)
      append_line "$HOME/.config/yabai/yabairc" \
        'source "$HOME/.config/livery/current/borders/borders.args"' ;;
    sketchybar)
      shim="$HOME/.config/sketchybar/colors.lua"
      mkdir -p "$(dirname "$shim")"
      backup_once "$shim"
      cat > "$shim" <<'LUA'
local root = os.getenv("HOME") .. "/.config/livery"
local current = root .. "/current/sketchybar/colors.lua"
local fallback = root .. "/default/sketchybar/colors.lua"

local ok, colors = pcall(dofile, current)
if ok then return colors end

return dofile(fallback)
LUA
      ;;
    nvim)
      plugins="$HOME/.config/nvim/lua/plugins"
      if [ ! -d "$plugins" ]; then
        echo "  nvim: no lazy.nvim plugins dir at $plugins — wire it by hand"
        return 1
      fi
      cat > "$plugins/livery.lua" <<LUA
return {
  {
    dir = "$REPO_ROOT/livery.nvim",
    name = "livery.nvim",
    lazy = false,
    priority = 999,
    config = function()
      require("livery").setup()
    end,
  },
}
LUA
      ;;
    *) return 1 ;;
  esac
}

WIRE=ask
case "${1:-}" in
  --wire) WIRE=yes ;;
  --no-wire) WIRE=no ;;
esac

echo ""
echo "loader wiring"
for adapter in "$REPO_ROOT"/adapters/*; do
  [ -x "$adapter" ] || continue
  name=$(basename "$adapter")
  printf '\n%s:\n' "$name"
  # loader failures are guidance, not installer failures.
  if "$adapter" loader-check; then
    continue
  fi
  want=n
  if [ "$WIRE" = yes ]; then
    want=y
  elif [ "$WIRE" = ask ] && [ -t 0 ]; then
    printf '  wire it now (existing file kept at *.pre-livery)? [y/N] '
    read -r want || want=n
  fi
  case $want in
    y|Y)
      if wire_loader "$name"; then
        "$adapter" loader-check || true
      fi
      ;;
  esac
done

# permissions command -v can't see: TCC grants and yabai's own setup.
cat <<'EOF'

system permissions
  audio-reactive wallpapers need a one-time Screen & System Audio
  Recording grant to ~/Applications/Fresco.app. run `fresco
  audio-permission` for the exact steps. ungranted, wallpapers play
  silent; fresco never raises the prompt in the background.
EOF
if command -v yabai >/dev/null 2>&1; then
  cat <<'EOF'
  yabai's scripting addition (SIP + sudoers, see the yabai wiki) belongs
  to your yabai setup. vestiary adapters only query yabai and don't
  need it; the borders loader rides yabairc.
EOF
fi

cat <<'EOF'

next steps
  livery apply default
  wire any missing loader lines from the report above
  livery apply <profile>

  livery list shows profiles
  fresco set <path-or-workshop-id> starts a live wallpaper
EOF
