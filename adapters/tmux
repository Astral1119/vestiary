#!/bin/sh
# vestiary adapter: tmux
# Contract: ../contract/SPEC.md Â§3 â€” verbs: render <manifest> <outdir> |
# validate <outdir> | reload <profiledir> | loader-check.
# Exit codes: 0 success Â· 1 operation failed Â· 2 usage/unknown verb.
# Consumes: ui.*, signals.*, targets.tmux.* (override // fallback idiom).
# Emits: <outdir>/livery.conf â€” @livery_* user options (palette for format
# strings) plus directly-set style options. Colors resolve wrapped {hex,rgb}
# v3 values or legacy bare hex.
set -eu

FRAGMENT_NAME="livery.conf"
TMUX_CONF="${LIVERY_TMUX_CONF:-$HOME/.config/tmux/tmux.conf}"
LOADER_LINE="livery/current/tmux/livery.conf"

JQ_UNWRAP='def uw: if type == "object" and has("hex") then .hex else . end;'

cv() { # cv <jq-expr> <manifest> â€” color value as bare hex
  jq -r "$JQ_UNWRAP($1) | uw" "$2"
}

render() {
  manifest=$1
  outdir=$2
  [ -r "$manifest" ] || { echo "render: manifest unreadable: $manifest" >&2; exit 1; }
  mkdir -p "$outdir"

  bg=$(cv '.targets.tmux.bg // .ui.background' "$manifest")
  fg=$(cv '.targets.tmux.fg // .ui.text' "$manifest")
  muted=$(cv '.targets.tmux.muted // .ui.textMuted' "$manifest")
  accent=$(cv '.targets.tmux.accent // .ui.primary' "$manifest")
  secondary=$(cv '.targets.tmux.secondary // .ui.secondary' "$manifest")
  outline=$(cv '.targets.tmux.outline // .ui.outline' "$manifest")
  outline_variant=$(cv '.targets.tmux.outlineVariant // .ui.outlineVariant // .ui.outline' "$manifest")
  selection=$(cv '.targets.tmux.selection // .ui.selection' "$manifest")
  surface=$(cv '.targets.tmux.surface // .ui.surface' "$manifest")
  attention=$(cv '.targets.tmux.attention // .signals.attention' "$manifest")
  success=$(cv '.targets.tmux.success // .signals.success' "$manifest")
  warning=$(cv '.targets.tmux.warning // .signals.warning' "$manifest")
  error=$(cv '.targets.tmux.error // .signals.error' "$manifest")
  info=$(cv '.targets.tmux.info // .signals.info' "$manifest")

  for value in "$bg" "$fg" "$muted" "$accent" "$secondary" "$outline" \
    "$outline_variant" "$selection" "$surface" "$attention" "$success" \
    "$warning" "$error" "$info"; do
    case "$value" in
      \#[0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f]) ;;
      *) echo "render: non-hex color resolved: '$value'" >&2; exit 1 ;;
    esac
  done

  cat > "$outdir/$FRAGMENT_NAME" <<EOF
# Generated by vestiary/adapters/tmux â€” do not edit.
# Palette (for format strings via #{@livery_*}):
set -g @livery_bg "$bg"
set -g @livery_fg "$fg"
set -g @livery_muted "$muted"
set -g @livery_accent "$accent"
set -g @livery_secondary "$secondary"
set -g @livery_outline "$outline"
set -g @livery_outline_variant "$outline_variant"
set -g @livery_selection "$selection"
set -g @livery_surface "$surface"
set -g @livery_attention "$attention"
set -g @livery_success "$success"
set -g @livery_warning "$warning"
set -g @livery_error "$error"
set -g @livery_info "$info"
# Derived styles (status bg stays default: transparency over the themed
# terminal background is the point):
set -g status-style "bg=default,fg=$fg"
set -g message-style "bg=$surface,fg=$fg"
set -g message-command-style "bg=$surface,fg=$fg"
set -g mode-style "bg=$selection,fg=$fg"
set -g pane-border-style "fg=$outline_variant"
set -g pane-active-border-style "fg=$accent"
set -g copy-mode-match-style "bg=$selection,fg=$fg"
set -g copy-mode-current-match-style "bg=$accent,fg=$bg"
setw -g window-status-bell-style "bold,fg=$error"
EOF
  echo "rendered tmux fragment: $outdir/$FRAGMENT_NAME"
}

validate() {
  outdir=$1
  fragment="$outdir/$FRAGMENT_NAME"
  [ -r "$fragment" ] || { echo "validate: fragment missing: $fragment" >&2; exit 1; }
  if ! command -v tmux >/dev/null 2>&1; then
    echo "validate: tmux not installed â€” skipping parse check"
    exit 0
  fi
  socket="livery-validate-$$"
  if tmux -L "$socket" -f "$fragment" start-server \; kill-server 2>"$outdir/.validate-err"; then
    rm -f "$outdir/.validate-err"
    echo "tmux fragment parses"
  else
    echo "validate: tmux rejected fragment:" >&2
    cat "$outdir/.validate-err" >&2
    rm -f "$outdir/.validate-err"
    tmux -L "$socket" kill-server 2>/dev/null || true
    exit 1
  fi
}

reload() {
  profiledir=$1
  fragment="$profiledir/tmux/$FRAGMENT_NAME"
  if ! command -v tmux >/dev/null 2>&1 || ! tmux has-session 2>/dev/null; then
    echo "tmux not running â€” nothing to reload"
    exit 0
  fi
  if tmux source-file "$fragment" 2>&1; then
    echo "tmux reloaded"
  else
    echo "reload: tmux rejected fragment at runtime" >&2
    exit 1
  fi
}

loader_check() {
  if ! command -v tmux >/dev/null 2>&1; then
    echo "loader n/a: tmux not installed"
    exit 0
  fi
  if [ -r "$TMUX_CONF" ] && grep -Fq "$LOADER_LINE" "$TMUX_CONF"; then
    echo "loader installed: $TMUX_CONF"
    exit 0
  fi
  echo "loader missing: add 'source-file -q ~/.config/$LOADER_LINE' to $TMUX_CONF"
  exit 1
}

case "${1:-}" in
  render)       [ $# -eq 3 ] || { echo "usage: tmux render <manifest> <outdir>" >&2; exit 2; }
                render "$2" "$3" ;;
  validate)     [ $# -eq 2 ] || { echo "usage: tmux validate <outdir>" >&2; exit 2; }
                validate "$2" ;;
  reload)       [ $# -eq 2 ] || { echo "usage: tmux reload <profiledir>" >&2; exit 2; }
                reload "$2" ;;
  loader-check) loader_check ;;
  *)            echo "unknown verb: ${1:-<none>} (render|validate|reload|loader-check)" >&2
                exit 2 ;;
esac
