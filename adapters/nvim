#!/bin/sh
# vestiary adapter: nvim
# Contract: ../contract/SPEC.md §3 — verbs: render <manifest> <outdir> |
# validate <outdir> | reload <profiledir> | loader-check.
# Exit codes: 0 success · 1 operation failed · 2 usage/unknown verb.
# Emits: <outdir>/livery.lua — a pure-data Lua module (variant, ui, signals,
# terminal) consumed by livery.nvim, which handles live re-apply itself via a
# file watcher — hence reload is a successful no-op (SPEC §5).
set -eu

FRAGMENT_NAME="livery.lua"
NVIM_CONFIG="${LIVERY_NVIM_CONFIG:-$HOME/.config/nvim}"

render() {
  manifest=$1
  outdir=$2
  [ -r "$manifest" ] || { echo "render: manifest unreadable: $manifest" >&2; exit 1; }
  mkdir -p "$outdir"
  jq -r '
    def uw: if type == "object" and has("hex") then .hex else . end;
    def lua_entries: to_entries
      | map(select(.value | uw | type == "string"))
      | map("    " + .key + " = \"" + (.value | uw) + "\",")
      | join("\n");
    "-- Generated by vestiary/adapters/nvim — do not edit.",
    "return {",
    "  variant = \"" + .variant + "\",",
    "  ui = {",
    (.ui | lua_entries),
    "  },",
    "  signals = {",
    (.signals | lua_entries),
    "  },",
    "  terminal = {",
    ([.terminal | to_entries[]
      | select(.key != "ansi" and .key != "base16")
      | select(.value | uw | type == "string")
      | "    " + .key + " = \"" + (.value | uw) + "\","] | join("\n")),
    "    ansi = { " + ([.terminal.ansi[] | uw | "\"" + . + "\""] | join(", ")) + " },",
    "    base16 = { " + ([(.terminal.base16 // [])[] | uw | "\"" + . + "\""] | join(", ")) + " },",
    "  },",
    "}"
  ' "$manifest" > "$outdir/$FRAGMENT_NAME" || {
    echo "render: jq failed" >&2
    exit 1
  }
  echo "rendered nvim fragment: $outdir/$FRAGMENT_NAME"
}

validate() {
  outdir=$1
  fragment="$outdir/$FRAGMENT_NAME"
  [ -r "$fragment" ] || { echo "validate: fragment missing: $fragment" >&2; exit 1; }
  if command -v luac >/dev/null 2>&1; then
    luac -p "$fragment" || { echo "validate: luac rejected fragment" >&2; exit 1; }
    echo "nvim fragment parses"
  elif command -v nvim >/dev/null 2>&1; then
    nvim -l "$fragment" >/dev/null 2>&1 || { echo "validate: nvim -l rejected fragment" >&2; exit 1; }
    echo "nvim fragment parses"
  else
    echo "validate: no lua parser available — skipping"
  fi
}

reload() {
  # livery.nvim watches the contract dir and re-applies on flip; running
  # instances need no external nudge and absent ones are success by contract.
  echo "nvim reload delegated to livery.nvim watcher"
  exit 0
}

loader_check() {
  if [ -d "$NVIM_CONFIG" ] && grep -rq "livery" "$NVIM_CONFIG/lua/plugins" 2>/dev/null; then
    echo "loader installed: livery.nvim spec found in $NVIM_CONFIG/lua/plugins"
    exit 0
  fi
  echo "loader missing: add a lazy.nvim spec for ~/personal/vestiary/livery.nvim"
  exit 1
}

case "${1:-}" in
  render)       [ $# -eq 3 ] || { echo "usage: nvim render <manifest> <outdir>" >&2; exit 2; }
                render "$2" "$3" ;;
  validate)     [ $# -eq 2 ] || { echo "usage: nvim validate <outdir>" >&2; exit 2; }
                validate "$2" ;;
  reload)       [ $# -eq 2 ] || { echo "usage: nvim reload <profiledir>" >&2; exit 2; }
                reload "$2" ;;
  loader-check) loader_check ;;
  *)            echo "unknown verb: ${1:-<none>} (render|validate|reload|loader-check)" >&2
                exit 2 ;;
esac
