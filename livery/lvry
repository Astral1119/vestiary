#!/bin/sh
set -eu

ROOT=$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)
APP="${XDG_CACHE_HOME:-$HOME/.cache}/livery/Livery.app"
BIN="$APP/Contents/MacOS/lvry"
PROCESS_PATTERN="^(/private)?${BIN}$"
LOCK="/tmp/livery-$(id -u).launch.lock"
READY="/tmp/livery-$(id -u).ready"
SOURCES="$ROOT/LiveryPreview.swift $ROOT/BarLegibility.swift $ROOT/Info.plist"

running_pids() {
  pgrep -f "$PROCESS_PATTERN" 2>/dev/null || true
}

clean_stale_ready() {
  [ -f "$READY" ] || return 0
  ready_pid=$(cat "$READY" 2>/dev/null || printf '')
  if [ -z "$ready_pid" ] || ! kill -0 "$ready_pid" 2>/dev/null; then
    rm -f "$READY"
  fi
}

binary_stale() {
  [ -x "$BIN" ] || return 0
  for source in $SOURCES; do
    if [ "$source" -nt "$BIN" ]; then
      return 0
    fi
  done
  return 1
}

stop_instances() {
  pids=$(running_pids)
  [ -n "$pids" ] || { rm -f "$READY"; return 0; }
  printf '%s\n' "$pids" | while IFS= read -r pid; do
    kill -TERM "$pid" 2>/dev/null || true
  done
  attempt=0
  while [ "$attempt" -lt 40 ] && [ -n "$(running_pids)" ]; do
    sleep 0.05
    attempt=$((attempt + 1))
  done
  pids=$(running_pids)
  if [ -n "$pids" ]; then
    printf '%s\n' "$pids" | while IFS= read -r pid; do
      kill -KILL "$pid" 2>/dev/null || true
    done
  fi
  rm -f "$READY"
}

toggle_single_instance() {
  pids=$(running_pids)
  [ -n "$pids" ] || return 1

  primary=""
  if [ -f "$READY" ]; then
    ready_pid=$(cat "$READY")
    if printf '%s\n' "$pids" | grep -Fxq "$ready_pid"; then
      primary=$ready_pid
    fi
  fi
  if [ -z "$primary" ]; then
    primary=$(printf '%s\n' "$pids" | sort -n | head -n 1)
  fi
  printf '%s\n' "$pids" | while IFS= read -r pid; do
    if [ "$pid" != "$primary" ]; then
      kill -TERM "$pid" 2>/dev/null || true
    fi
  done

  attempt=0
  while [ "$attempt" -lt 80 ]; do
    if [ -f "$READY" ] && [ "$(cat "$READY")" = "$primary" ]; then
      open "$APP"
      return 0
    fi
    sleep 0.05
    attempt=$((attempt + 1))
  done

  # Readiness never confirmed (stale file, slow instance). A reopen event
  # is harmless either way — fall back to it rather than failing the keybind.
  echo "Livery readiness unconfirmed; sending reopen anyway" >>/tmp/lvry.log 2>&1 || true
  open "$APP"
  return 0
}

case "${1:-toggle}" in
  restart)
    stop_instances
    ;;
  toggle)
    if binary_stale && [ -n "$(running_pids)" ]; then
      # Sources changed since the running build: restart through the cold
      # path so the keybind always reflects current code.
      osascript -e 'display notification "sources changed — rebuilding" with title "Livery"' \
        2>/dev/null || true
      stop_instances
    fi
    ;;
  *)
    echo "usage: lvry [toggle|restart]" >&2
    exit 2
    ;;
esac

clean_stale_ready

if toggle_single_instance; then
  exit 0
fi

if [ -f "$LOCK/pid" ]; then
  lock_pid=$(cat "$LOCK/pid")
  if ! kill -0 "$lock_pid" 2>/dev/null; then
    rm -f "$LOCK/pid"
    rmdir "$LOCK" 2>/dev/null || true
  fi
fi

if mkdir "$LOCK" 2>/dev/null; then
  printf '%s\n' "$$" > "$LOCK/pid"
  trap 'rm -f "$LOCK/pid"; rmdir "$LOCK" 2>/dev/null || true' EXIT HUP INT TERM
  "$ROOT/run" >/tmp/lvry.log 2>&1
  exit 0
fi

# Another shortcut invocation is already compiling or launching Livery. Wait
# for that single instance, then treat this invocation as the next toggle.
attempt=0
while [ "$attempt" -lt 80 ]; do
  if toggle_single_instance; then
    exit 0
  fi
  sleep 0.05
  attempt=$((attempt + 1))
done

echo "Livery launch timed out; see /tmp/lvry.log" >&2
exit 1
