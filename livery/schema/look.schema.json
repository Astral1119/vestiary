{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "local.vestiary.livery.look.v2",
  "title": "Livery Look specification and resolved manifest",
  "oneOf": [
    {
      "$ref": "#/$defs/spec"
    },
    {
      "$ref": "#/$defs/manifest"
    }
  ],
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "color": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "hex",
            "rgb"
          ],
          "additionalProperties": false,
          "properties": {
            "hex": {
              "type": "string",
              "pattern": "^#[0-9a-f]{6}$"
            },
            "rgb": {
              "type": "array",
              "minItems": 3,
              "maxItems": 3,
              "items": {
                "type": "integer",
                "minimum": 0,
                "maximum": 255
              }
            }
          }
        },
        {
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}$"
        }
      ]
    },
    "descriptor": {
      "type": "object",
      "required": [
        "digest",
        "mediaType",
        "size"
      ],
      "properties": {
        "digest": {
          "$ref": "#/$defs/digest"
        },
        "mediaType": {
          "type": "string",
          "minLength": 1
        },
        "size": {
          "type": "integer",
          "minimum": 0
        },
        "dimensions": {
          "type": "array",
          "prefixItems": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "integer",
              "minimum": 1
            }
          ],
          "items": false
        },
        "orientation": {
          "type": "integer",
          "minimum": 1,
          "maximum": 8
        },
        "color": {
          "type": "object"
        },
        "artifact": {
          "type": "string"
        },
        "derivationDigest": {
          "$ref": "#/$defs/digest"
        }
      },
      "additionalProperties": true
    },
    "coherence": {
      "type": "object",
      "required": [
        "authority",
        "operation",
        "constraints",
        "wallpaperScope"
      ],
      "properties": {
        "authority": {
          "enum": [
            "wallpaper",
            "theme",
            "pair",
            "independent"
          ]
        },
        "operation": {
          "enum": [
            "derive-theme",
            "grade-wallpaper",
            "identity"
          ]
        },
        "constraints": {
          "type": "object",
          "properties": {
            "preserveThemeDomains": {
              "type": "array",
              "items": {
                "enum": [
                  "ui",
                  "signals",
                  "terminal",
                  "presentation",
                  "effects"
                ]
              },
              "uniqueItems": true
            }
          },
          "additionalProperties": true
        },
        "wallpaperScope": {
          "const": "all-managed-spaces"
        }
      },
      "additionalProperties": false
    },
    "step": {
      "type": "object",
      "required": [
        "operation",
        "engine",
        "version",
        "parameters"
      ],
      "properties": {
        "operation": {
          "type": "string",
          "minLength": 1
        },
        "engine": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "parameters": {
          "type": "object"
        },
        "inputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/digest"
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/digest"
          }
        }
      },
      "additionalProperties": false
    },
    "placement": {
      "type": "object",
      "required": [
        "mode",
        "focalPoint"
      ],
      "properties": {
        "mode": {
          "enum": [
            "fill",
            "fit",
            "stretch",
            "center"
          ]
        },
        "focalPoint": {
          "type": "array",
          "prefixItems": [
            {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          ],
          "items": false
        }
      },
      "additionalProperties": false
    },
    "spec": {
      "type": "object",
      "required": [
        "schemaVersion",
        "kind",
        "id",
        "label",
        "inputs",
        "coherence",
        "pipeline",
        "placement"
      ],
      "properties": {
        "schemaVersion": {
          "const": 2
        },
        "kind": {
          "const": "look-spec"
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "inputs": {
          "type": "object",
          "minProperties": 1
        },
        "coherence": {
          "$ref": "#/$defs/coherence"
        },
        "pipeline": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/step"
          }
        },
        "placement": {
          "$ref": "#/$defs/placement"
        }
      },
      "additionalProperties": false
    },
    "manifest": {
      "allOf": [
        {
          "type": "object",
          "required": [
            "schemaVersion",
            "kind",
            "id",
            "label",
            "specDigest",
            "inputs",
            "coherence",
            "pipeline",
            "placement",
            "variant",
            "ui",
            "signals",
            "terminal",
            "presentation",
            "effects",
            "locks",
            "outputs",
            "provenance",
            "evidence",
            "meta"
          ],
          "properties": {
            "schemaVersion": {
              "const": 3
            },
            "kind": {
              "const": "look-manifest"
            },
            "id": {
              "type": "string",
              "minLength": 1
            },
            "label": {
              "type": "string",
              "minLength": 1
            },
            "specDigest": {
              "$ref": "#/$defs/digest"
            },
            "inputs": {
              "type": "object",
              "minProperties": 1
            },
            "coherence": {
              "$ref": "#/$defs/coherence"
            },
            "pipeline": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/step"
              }
            },
            "placement": {
              "$ref": "#/$defs/placement"
            },
            "variant": {
              "enum": [
                "dark",
                "light"
              ]
            },
            "ui": {
              "type": "object",
              "required": [
                "background",
                "surface",
                "surfaceElevated",
                "text",
                "textMuted",
                "primary",
                "secondary",
                "tertiary",
                "outline",
                "selection"
              ],
              "additionalProperties": {
                "$ref": "#/$defs/color"
              }
            },
            "signals": {
              "type": "object",
              "required": [
                "success",
                "warning",
                "error",
                "info",
                "attention"
              ],
              "additionalProperties": {
                "$ref": "#/$defs/color"
              }
            },
            "terminal": {
              "type": "object"
            },
            "presentation": {
              "type": "object"
            },
            "effects": {
              "type": "object"
            },
            "locks": {
              "type": "object"
            },
            "targets": {
              "type": "object"
            },
            "outputs": {
              "type": "object",
              "required": [
                "theme",
                "wallpaper"
              ],
              "properties": {
                "theme": {
                  "type": "object",
                  "required": [
                    "digest",
                    "format"
                  ],
                  "properties": {
                    "digest": {
                      "$ref": "#/$defs/digest"
                    },
                    "format": {
                      "const": "livery-semantic-v2"
                    }
                  },
                  "additionalProperties": false
                },
                "wallpaper": {
                  "oneOf": [
                    {
                      "$ref": "#/$defs/descriptor"
                    },
                    {
                      "type": "object",
                      "required": [
                        "kind",
                        "id"
                      ],
                      "properties": {
                        "kind": {
                          "const": "provider-state"
                        },
                        "id": {
                          "type": "string",
                          "minLength": 1
                        }
                      },
                      "additionalProperties": false
                    }
                  ]
                }
              },
              "additionalProperties": false
            },
            "provenance": {
              "type": "object",
              "required": [
                "materials",
                "steps",
                "reproducibility"
              ],
              "properties": {
                "materials": {
                  "type": "array"
                },
                "steps": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/step"
                  }
                },
                "environment": {
                  "type": "object"
                },
                "reproducibility": {
                  "enum": [
                    "stored",
                    "replayable",
                    "reproducible"
                  ]
                }
              },
              "additionalProperties": true
            },
            "evidence": {
              "type": "object"
            },
            "meta": {
              "type": "object",
              "required": [
                "name",
                "producer",
                "resolvedAt",
                "scope"
              ],
              "properties": {
                "name": {
                  "type": "string",
                  "minLength": 1
                },
                "source": {},
                "producer": {
                  "type": "object"
                },
                "resolvedAt": {
                  "type": "string"
                },
                "scope": {
                  "const": "global"
                }
              }
            }
          },
          "additionalProperties": true
        }
      ]
    }
  }
}
