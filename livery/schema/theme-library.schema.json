{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "local.vestiary.livery.theme-library.v1",
  "title": "Livery semantic theme library",
  "type": "object",
  "required": ["schemaVersion", "generatedBy", "themes"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "generatedBy": { "type": "string", "minLength": 1 },
    "themes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "label",
          "style",
          "summary",
          "tags",
          "ref",
          "theme"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "label": { "type": "string", "minLength": 1 },
          "style": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 },
          "tags": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "ref": { "type": "string", "minLength": 1 },
          "theme": {
            "type": "object",
            "required": [
              "schemaVersion",
              "kind",
              "id",
              "label",
              "variant",
              "ui",
              "signals",
              "terminal",
              "presentation",
              "effects",
              "locks"
            ],
            "properties": {
              "schemaVersion": { "const": 2 },
              "kind": { "const": "semantic-theme" }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
