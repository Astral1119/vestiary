const grid = document.getElementById("grid");
const q = document.getElementById("q");
const typeSel = document.getElementById("type");
const statusEl = document.getElementById("status");
let current = "", applying = null, timer = null;

async function refreshStatus() {
  const s = await fetch("/api/status").then(r => r.json());
  current = s.current || ""; applying = s.applying;
  statusEl.textContent = applying ? "applying " + applying + "…" : "";
  document.querySelectorAll("article").forEach(a => {
    a.classList.toggle("current", current.endsWith("/" + a.dataset.id));
  });
}

async function search() {
  statusEl.textContent = "searching…";
  const url = `/api/search?q=${encodeURIComponent(q.value)}&type=${typeSel.value}&n=24`;
  const items = await fetch(url).then(r => r.json());
  statusEl.textContent = "";
