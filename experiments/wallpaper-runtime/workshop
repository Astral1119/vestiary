def gallery(port, auto_open):
    import http.server
    import threading
    from concurrent.futures import ThreadPoolExecutor
    from urllib.parse import parse_qs, urlparse

    cache = os.path.join(SCRIPT_DIR, ".browse-cache")
    os.makedirs(cache, exist_ok=True)
    palette = livery_colors()
    page = GALLERY_PAGE
    for key, token in [("surface", "__SURFACE__"), ("background", "__BACKGROUND__"),
                       ("text", "__TEXT__"), ("muted", "__MUTED__"),
                       ("accent_a", "__ACCENT_A__"), ("accent_b", "__ACCENT_B__")]:
        page = page.replace(token, palette[key])
    state = {"applying": None}
    config_path = os.path.expanduser("~/.config/wallpaper-runtime/current")

    class Handler(http.server.BaseHTTPRequestHandler):
        def log_message(self, *args):
            pass

        def send_json(self, payload, code=200):
            body = json.dumps(payload).encode()
            self.send_response(code)
            self.send_header("Content-Type", "application/json")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)

        def do_GET(self):
            url = urlparse(self.path)
            if url.path == "/":
                body = page.encode()
                self.send_response(200)
                self.send_header("Content-Type", "text/html; charset=utf-8")
                self.send_header("Content-Length", str(len(body)))
                self.end_headers()
                self.wfile.write(body)
            elif url.path == "/api/search":
                params = parse_qs(url.query)
                query = params.get("q", [""])[0]
                kind = params.get("type", ["web"])[0]
                count = min(int(params.get("n", ["24"])[0]), 60)
                files = query_details(query, kind, count)
                with ThreadPoolExecutor(max_workers=8) as pool:
                    previews = list(pool.map(lambda f: fetch_preview(f, cache), files))
                items = []
                for f, preview in zip(files, previews):
                    tags = [t.get("tag", "") for t in f.get("tags", [])]
                    items.append({
                        "id": str(f["publishedfileid"]),
                        "title": f.get("title", "?"),
                        "size": round(int(f.get("file_size", 0)) / 1e6, 1),
                        "subs": int(f.get("subscriptions", 0)),
                        "preview": preview,
                        "playable": "Web" in tags or "Video" in tags,
                    })
                self.send_json(items)
            elif url.path == "/api/status":
                current = ""
                if os.path.exists(config_path):
                    current = open(config_path).read().strip()
                self.send_json({"current": current, "applying": state["applying"]})
            elif url.path.startswith("/previews/"):
                name = os.path.basename(url.path)
                path = os.path.join(cache, name)
                if not os.path.exists(path):
                    self.send_response(404)
                    self.end_headers()
                    return
                mime = {"gif": "image/gif", "png": "image/png"}.get(
                    name.rsplit(".", 1)[-1], "image/jpeg")
                with open(path, "rb") as handle:
                    body = handle.read()
                self.send_response(200)
                self.send_header("Content-Type", mime)
                self.send_header("Content-Length", str(len(body)))
                self.end_headers()
                self.wfile.write(body)
            else:
                self.send_response(404)
                self.end_headers()

        def do_POST(self):
            if urlparse(self.path).path != "/api/apply":
                self.send_response(404)
                self.end_headers()
                return
            length = int(self.headers.get("Content-Length", 0))
            item_id = str(json.loads(self.rfile.read(length))["id"])
            state["applying"] = item_id

            def work():
                subprocess.run([os.path.join(SCRIPT_DIR, "wallpaperctl"), "set", item_id],
                               capture_output=True)
                state["applying"] = None

            threading.Thread(target=work, daemon=True).start()
            self.send_json({"ok": True})

    server = http.server.ThreadingHTTPServer(("127.0.0.1", port), Handler)
    print(f"gallery: http://127.0.0.1:{port}  (Ctrl-C to stop)")
    if auto_open:
        subprocess.run(["open", f"http://127.0.0.1:{port}"])
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        pass


def details(item_id):
    data = urllib.parse.urlencode(
        {"itemcount": 1, "publishedfileids[0]": item_id}).encode()
    url = "https://api.steampowered.com/ISteamRemoteStorage/GetPublishedFileDetails/v1/"
    f = json.loads(http(url, data))["response"]["publishedfiledetails"][0]
    return f


def info(item_id):
    f = details(item_id)
    tags = ",".join(t.get("tag", "") for t in f.get("tags", []))
    size = int(f.get("file_size", 0)) / 1e6
    print(f"{f.get('title','?')}  ({size:.1f} MB)")
    print(f"tags: {tags}")
    print(f"https://steamcommunity.com/sharedfiles/filedetails/?id={item_id}")
    playable = "Web" in tags or "Video" in tags
    if not playable:
        print("note: scene wallpaper — downloads fine, but this runtime "
              "renders web/video only (see FEASIBILITY.md phase 2)")


def get(item_id):
    target = os.path.join(CONTENT_DIR, str(item_id))
    result = subprocess.run(
        ["steamcmd", f"+login {steam_user()}",
         f"+workshop_download_item {APP_ID} {item_id}", "+quit"],
        capture_output=True, text=True)
    if "Success" not in result.stdout:
        print(result.stdout.strip().splitlines()[-3:], file=sys.stderr)
        sys.exit("download failed (is the cached login still valid?)")
    print(target)
    return target


def main():
    args = sys.argv[1:]
    if not args:
        sys.exit(__doc__.strip())
    command = args[0]
    if command in ("search", "browse"):
        kind = "web"
        count = 30 if command == "browse" else 15
        auto_open = True
        rest = []
        i = 1
        while i < len(args):
            if args[i] == "--type":
                kind = args[i + 1]; i += 2
            elif args[i] == "--n":
                count = int(args[i + 1]); i += 2
            elif args[i] == "--no-open":
                auto_open = False; i += 1
            else:
                rest.append(args[i]); i += 1
        if command == "search":
            search(" ".join(rest), kind, count)
        else:
            browse(" ".join(rest), kind, count, auto_open)
    elif command == "gallery":
        port = 8991
        auto_open = True
        i = 1
        while i < len(args):
            if args[i] == "--port":
                port = int(args[i + 1]); i += 2
            elif args[i] == "--no-open":
                auto_open = False; i += 1
            else:
                i += 1
        gallery(port, auto_open)
    elif command == "info" and len(args) > 1:
        info(args[1])
    elif command == "get" and len(args) > 1:
        get(args[1])
    elif command == "run" and len(args) > 1:
        path = get(args[1])
        os.execv(os.path.join(SCRIPT_DIR, "run"), ["run", path])
    else:
        sys.exit(__doc__.strip())


if __name__ == "__main__":
    main()
