#!/usr/bin/env python3
"""Lifecycle control for the wallpaper runtime.

  wallpaperctl set <path-or-workshop-id>   # switch wallpaper (starts if needed)
  wallpaperctl clear                       # tear down to idle (static desktop)
  wallpaperctl repose [quiet|loud|off]     # toggle the repose cover
                                           # (explicit variant enters/switches)
  wallpaperctl repose-bg <scene|desktop>   # cover scene (path, workshop id,
                                           # or "desktop" to mirror it)
  wallpaperctl repose-look <zephyr|pixel>  # composition language

Repose selection lives in one record (~/.config/wallpaper-runtime/
repose.json: look, scene, variant, grade, night, pixels); these
subcommands and the in-cover keys (arrows scene, tab look, x pixels,
v variant, g/n treatments) are both thin writers over it, applied live
to an open cover.
  wallpaperctl start | stop | restart
  wallpaperctl status
  wallpaperctl build                       # (re)compile the daemon binary
  wallpaperctl install-agent               # launchd agent: start at login
  wallpaperctl uninstall-agent

State lives in ~/.config/wallpaper-runtime/: `current` (wallpaper path),
`pid`, `log`, and `bin/wallpaper-runtime`. A running daemon hot-swaps on
SIGUSR1; `stop` uses launchctl when the agent is loaded so KeepAlive
doesn't resurrect it.
"""

import json
import os
import signal
import subprocess
import sys

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
SOURCE = os.path.join(SCRIPT_DIR, "WallpaperRuntime.swift")
STATE_DIR = os.path.expanduser("~/.config/wallpaper-runtime")
BIN = os.path.join(STATE_DIR, "bin", "wallpaper-runtime")
CONFIG = os.path.join(STATE_DIR, "current")
PIDFILE = os.path.join(STATE_DIR, "pid")
LOG = os.path.join(STATE_DIR, "log")
LABEL = "local.wallpaper-runtime"
PLIST = os.path.expanduser(f"~/Library/LaunchAgents/{LABEL}.plist")
APP_ID = 431960
WORKSHOP_DIR = os.path.expanduser(
    f"~/Library/Application Support/Steam/steamapps/workshop/content/{APP_ID}")


def build(force=False):
    os.makedirs(os.path.dirname(BIN), exist_ok=True)
    if (not force and os.path.exists(BIN)
            and os.path.getmtime(BIN) >= os.path.getmtime(SOURCE)):
        return
    print("compiling runtime…")
    subprocess.run(
        ["swiftc", "-O", "-warnings-as-errors",
         "-framework", "AppKit", "-framework", "WebKit",
         "-framework", "AVFoundation", SOURCE, "-o", BIN],
        check=True)


def runtime_pid():
    try:
        pid = int(open(PIDFILE).read().strip())
        os.kill(pid, 0)
        return pid
    except (OSError, ValueError):
        return None


def runtime_stale(pid):
    """True when the daemon process predates the current binary."""
    try:
        etime = subprocess.run(["ps", "-p", str(pid), "-o", "etime="],
                               capture_output=True, text=True).stdout.strip()
        parts = etime.replace("-", ":").split(":")
        seconds = 0
        for part in parts:
            seconds = seconds * 60 + int(part)
        if len(parts) == 4:   # dd:hh:mm:ss — the day field is *86400/60^3
            days, hours, minutes, secs = (int(p) for p in parts)
            seconds = days * 86400 + hours * 3600 + minutes * 60 + secs
        import time
        started = time.time() - seconds
        return os.path.getmtime(BIN) > started + 5
    except (OSError, ValueError):
        return False


def agent_installed():
    return os.path.exists(PLIST)


def agent_loaded():
    result = subprocess.run(
        ["launchctl", "print", f"gui/{os.getuid()}/{LABEL}"],
        capture_output=True)
    return result.returncode == 0


def resolve(target):
    if target.isdigit():
        path = os.path.join(WORKSHOP_DIR, target)
        if not os.path.exists(os.path.join(path, "project.json")):
            print(f"fetching workshop item {target}…")
            subprocess.run([os.path.join(SCRIPT_DIR, "workshop"), "get", target],
                           check=True, capture_output=True, text=True)
    else:
        path = os.path.abspath(os.path.expanduser(target))
        if not os.path.exists(path):
            sys.exit(f"no such wallpaper: {path}")
    # Preset items reference a base wallpaper; make sure it's present too.
    try:
        import json as json_module
        with open(os.path.join(path, "project.json")) as handle:
            dependency = json_module.load(handle).get("dependency")
        if dependency and not os.path.exists(
                os.path.join(WORKSHOP_DIR, str(dependency), "project.json")):
            print(f"fetching preset dependency {dependency}…")
            subprocess.run([os.path.join(SCRIPT_DIR, "workshop"), "get", str(dependency)],
                           check=True, capture_output=True, text=True)
    except (OSError, ValueError, NotADirectoryError):
        pass
    return path


def start():
    build()
    os.makedirs(STATE_DIR, exist_ok=True)
    if runtime_pid():
        print("already running")
        return
    if agent_installed():
        if agent_loaded():
            subprocess.run(["launchctl", "kickstart", f"gui/{os.getuid()}/{LABEL}"])
        else:
            subprocess.run(["launchctl", "bootstrap", f"gui/{os.getuid()}", PLIST])
        print("started (launchd)")
        return
    with open(LOG, "a") as log:
        subprocess.Popen([BIN, "--daemon"], stdout=log, stderr=log,
                         start_new_session=True)
    print(f"started (background; log: {LOG})")


def stop():
    if agent_loaded():
        subprocess.run(["launchctl", "bootout", f"gui/{os.getuid()}/{LABEL}"])
        print("stopped (agent unloaded; `start` reloads it)")
        return
    pid = runtime_pid()
    if pid:
        os.kill(pid, signal.SIGTERM)
        print("stopped")
    else:
        print("not running")


def set_wallpaper(target):
    path = resolve(target)
    os.makedirs(STATE_DIR, exist_ok=True)
    build()
    with open(CONFIG, "w") as handle:
        handle.write(path + "\n")
    pid = runtime_pid()
    if pid and runtime_stale(pid):
        print("runtime binary is newer than the daemon — restarting")
        os.kill(pid, signal.SIGTERM)
        for _ in range(20):
            if not runtime_pid():
                break
            import time
            time.sleep(0.1)
        pid = None
    if pid:
        os.kill(pid, signal.SIGUSR1)
        print(f"switched: {path}")
    else:
        start()
        print(f"set: {path}")


REPOSE_STATE = os.path.join(STATE_DIR, "repose.json")


def load_repose_state():
    state = {"look": "zephyr", "scene": "desktop", "variant": "quiet",
             "grade": "on", "night": "off", "pixels": "on"}
    try:
        with open(REPOSE_STATE) as handle:
            state.update(json.load(handle))
    except (OSError, ValueError):
        pass
    return state


def save_repose_state(state):
    os.makedirs(STATE_DIR, exist_ok=True)
    with open(REPOSE_STATE, "w") as handle:
        json.dump(state, handle, indent=2, sort_keys=True)
        handle.write("\n")


def signal_repose(verb):
    """Write the command file and signal the daemon (starting it if the verb
    needs a cover; a refresh with no daemon just applies at next entry)."""
    build()
    os.makedirs(STATE_DIR, exist_ok=True)
    path = os.path.join(SCRIPT_DIR, "repose")
    with open(os.path.join(STATE_DIR, "repose-command"), "w") as handle:
        handle.write(f"{verb}\n{path}\n")
    pid = runtime_pid()
    if pid and runtime_stale(pid):
        print("runtime binary is newer than the daemon — restarting")
        os.kill(pid, signal.SIGTERM)
        import time
        for _ in range(20):
            if not runtime_pid():
                break
            time.sleep(0.1)
        pid = None
    if not pid:
        if verb in ("exit", "refresh"):
            return
        start()
        import time
        for _ in range(30):
            pid = runtime_pid()
            if pid:
                break
            time.sleep(0.1)
    if not pid:
        sys.exit("runtime did not start; check the log")
    os.kill(pid, signal.SIGUSR2)


def repose(args):
    action = args[0] if args else "toggle"
    if action not in ("quiet", "loud", "off", "toggle"):
        sys.exit("usage: wallpaperctl repose [quiet|loud|off]")
    if action in ("quiet", "loud"):
        state = load_repose_state()
        state["variant"] = action
        save_repose_state(state)
    verb = ("exit" if action == "off"
            else "enter" if action in ("quiet", "loud") else "toggle")
    signal_repose(verb)
    print(f"repose: {verb}" + (f" ({action})" if action in ("quiet", "loud") else ""))


def repose_bg(args):
    """Set the cover scene in repose.json; applies live if covered."""
    state = load_repose_state()
    if not args:
        scene = state["scene"]
        print(f"repose scene: {scene if scene != 'desktop' else '(mirrors the desktop wallpaper)'}")
        return
    if args[0] in ("desktop", "off"):
        state["scene"] = "desktop"
    else:
        state["scene"] = resolve(args[0])
    save_repose_state(state)
    signal_repose("refresh")
    print(f"repose scene: {state['scene']}")


def repose_look(args):
    """Set the composition language in repose.json; applies live if covered."""
    state = load_repose_state()
    if not args:
        print(f"repose look: {state['look']}")
        return
    if args[0] not in ("zephyr", "pixel"):
        sys.exit("usage: wallpaperctl repose-look <zephyr|pixel>")
    state["look"] = args[0]
    save_repose_state(state)
    signal_repose("refresh")
    print(f"repose look: {state['look']}")


def clear():
    os.makedirs(STATE_DIR, exist_ok=True)
    with open(CONFIG, "w") as handle:
        handle.write("")
    pid = runtime_pid()
    if pid:
        os.kill(pid, signal.SIGUSR1)
        print("cleared (daemon idle)")
    else:
        print("cleared")


def status():
    pid = runtime_pid()
    print(f"running: {'yes (pid ' + str(pid) + ')' if pid else 'no'}")
    current = open(CONFIG).read().strip() if os.path.exists(CONFIG) else "(none)"
    print(f"wallpaper: {current}")
    agent = ("installed + loaded" if agent_loaded()
             else "installed" if agent_installed() else "none")
    print(f"agent: {agent}")
    print(f"log: {LOG}")


def install_agent():
    build()
    os.makedirs(os.path.dirname(PLIST), exist_ok=True)
    plist = f"""<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <key>Label</key><string>{LABEL}</string>
  <key>ProgramArguments</key><array>
    <string>{BIN}</string><string>--daemon</string>
  </array>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>StandardOutPath</key><string>{LOG}</string>
  <key>StandardErrorPath</key><string>{LOG}</string>
</dict></plist>
"""
    with open(PLIST, "w") as handle:
        handle.write(plist)
    if runtime_pid() and not agent_loaded():
        pid = runtime_pid()
        os.kill(pid, signal.SIGTERM)   # hand the process over to launchd
    subprocess.run(["launchctl", "bootstrap", f"gui/{os.getuid()}", PLIST])
    print(f"agent installed and loaded: {PLIST}")


def uninstall_agent():
    if agent_loaded():
        subprocess.run(["launchctl", "bootout", f"gui/{os.getuid()}/{LABEL}"])
    if os.path.exists(PLIST):
        os.remove(PLIST)
    print("agent removed")


def main():
    args = sys.argv[1:]
    if not args:
        sys.exit(__doc__.strip())
    command = args[0]
    if command == "set" and len(args) > 1:
        set_wallpaper(args[1])
    elif command == "repose":
        repose(args[1:])
    elif command == "repose-bg":
        repose_bg(args[1:])
    elif command == "repose-look":
        repose_look(args[1:])
    elif command == "clear":
        clear()
    elif command == "start":
        start()
    elif command == "stop":
        stop()
    elif command == "restart":
        stop()
        start()
    elif command == "status":
        status()
    elif command == "build":
        build(force=True)
        print(BIN)
    elif command == "install-agent":
        install_agent()
    elif command == "uninstall-agent":
        uninstall_agent()
    else:
        sys.exit(__doc__.strip())


if __name__ == "__main__":
    main()
