{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://livery.local/schema/wallpaper-library.schema.json",
  "title": "Livery local wallpaper library",
  "type": "object",
  "required": [
    "schemaVersion",
    "generatedBy",
    "fixtures"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "generatedBy": {
      "type": "string",
      "minLength": 1
    },
    "fixtures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "number",
          "name",
          "subtitle",
          "fileName",
          "credit",
          "assetPath",
          "assetDigest",
          "dimensions",
          "mediaType",
          "palettes"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "number": {
            "type": "integer",
            "minimum": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "assetPath": {
            "type": "string",
            "minLength": 1
          },
          "assetDigest": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          },
          "dimensions": {
            "type": "array",
            "prefixItems": [
              {
                "type": "integer",
                "minimum": 1
              },
              {
                "type": "integer",
                "minimum": 1
              }
            ],
            "minItems": 2,
            "maxItems": 2
          },
          "palettes": {
            "type": "array",
            "minItems": 3,
            "maxItems": 3
          }
        }
      }
    }
  }
}
